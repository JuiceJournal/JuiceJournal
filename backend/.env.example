# ===========================================
# Juice Journal — Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ---------- Database ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=juicejournal
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# ---------- Authentication ----------
# REQUIRED: Generate a strong secret (min 32 chars in production)
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d
REQUIRE_ADMIN_FOR_PRICE_SYNC=false

# ---------- Server ----------
PORT=3001
NODE_ENV=development
DB_AUTO_SYNC=true

# ---------- CORS (comma-separated origins) ----------
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ---------- Price Sync ----------
DEFAULT_LEAGUE=Mirage
PRICE_SYNC_INTERVAL=1
PRICE_SYNC_MIN_INTERVAL_MS=300000

# ---------- Path of Exile OAuth ----------
# Leave POE_CLIENT_ID empty to auto-enable mock mode in development.
# In production, register at https://www.pathofexile.com/developer/docs
POE_CLIENT_ID=
POE_REDIRECT_URI=http://127.0.0.1:34127/oauth/poe/callback
POE_SCOPES=account:profile account:characters
POE_CONTACT=your@email.com
POE_TOKEN_ENCRYPTION_KEY=CHANGE_ME_BEFORE_USING_REAL_POE_OAUTH

# ---------- Seed Script ----------
# SEED_USERNAME=admin
# SEED_EMAIL=admin@juicejournal.local
# SEED_PASSWORD=  (auto-generated if empty)

# ---------- pgAdmin (docker-compose only) ----------
PGADMIN_PASSWORD=CHANGE_ME
