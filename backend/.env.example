# Database Configuration
# Docker ile kullanmak icin:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=poefarm
DB_USER=postgres
DB_PASSWORD=postgres123

# Docker'siz yerel kurulum icin yukaridaki degerleri degistirin

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
REQUIRE_ADMIN_FOR_PRICE_SYNC=false

# Server Configuration
PORT=3001
NODE_ENV=development
DB_AUTO_SYNC=true

# PoE Ninja API
POE_NINJA_BASE_URL=https://poe.ninja/api/data
DEFAULT_LEAGUE=Mirage

# Path of Exile OAuth
POE_OAUTH_MOCK=true
POE_CLIENT_ID=
POE_REDIRECT_URI=http://127.0.0.1:34127/oauth/poe/callback
POE_SCOPES=account:profile
POE_CONTACT=support@example.com
POE_TOKEN_ENCRYPTION_KEY=change_this_before_using_real_poe_oauth

# Price Sync Interval (saat olarak)
PRICE_SYNC_INTERVAL=1
PRICE_SYNC_MIN_INTERVAL_MS=300000
