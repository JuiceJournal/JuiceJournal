# Database Configuration
# Docker ile kullanmak icin:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=poefarm
DB_USER=postgres
DB_PASSWORD=postgres123

# Docker'siz yerel kurulum icin yukaridaki degerleri degistirin

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=development

# PoE Ninja API
POE_NINJA_BASE_URL=https://poe.ninja/api/data
DEFAULT_LEAGUE=Ancestor

# Price Sync Interval (saat olarak)
PRICE_SYNC_INTERVAL=1
