{
  "name": "juice-journal-backend",
  "version": "1.0.0",
  "description": "Juice Journal Backend API",
  "main": "server.js",
  "scripts": {
    "build": "node scripts/build-check.js",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "node config/migrate.js",
    "db:seed": "node config/seed.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "docker:psql": "docker exec -it juice-journal-db psql -U postgres -d juicejournal"
  },
  "dependencies": {
    "axios": "1.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "uuid": "file:vendor/uuid-safe",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "juice-journal",
    "poe",
    "path-of-exile"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "follow-redirects": "1.16.0",
    "uuid": "file:vendor/uuid-safe"
  }
}
