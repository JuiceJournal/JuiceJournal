{
  "name": "juice-journal-desktop",
  "version": "1.0.0",
  "description": "Juice Journal Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test tests/*.test.js",
    "test:desktop": "node --test tests/*.test.js",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test e2e/settings-smoke.spec.js e2e/overlay-smoke.spec.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "pack": "electron-builder --dir",
    "icon:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-icon-assets.ps1",
    "icon:test": "node --test tests/branding.test.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "1.15.0",
    "chokidar": "^3.5.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "node-global-key-listener": "^0.1.1",
    "tesseract.js": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.2",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "JuiceJournal.Desktop",
    "productName": "Juice Journal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "JuiceJournal",
        "repo": "JuiceJournal"
      }
    ]
  },
  "keywords": [
    "juice-journal",
    "poe",
    "path-of-exile"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "follow-redirects": "1.16.0"
  }
}
