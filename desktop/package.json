{
  "name": "juice-journal-desktop",
  "version": "1.0.0",
  "description": "Juice Journal Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "start:overwolf": "ow-electron .",
    "dev:overwolf": "ow-electron . --dev",
    "dev:overwolf:qa": "ow-electron . --dev --owepm-packages-url=https://electronapi-qa.overwolf.com/packages",
    "test": "node --test tests/*.test.js",
    "test:desktop": "node --test tests/*.test.js",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test e2e/settings-smoke.spec.js e2e/overlay-smoke.spec.js",
    "bridge:build": "dotnet build native-bridge/JuiceJournal.NativeBridge.csproj",
    "bridge:run": "dotnet run --project native-bridge/JuiceJournal.NativeBridge.csproj",
    "build": "npm run bridge:build && electron-builder",
    "build:win": "npm run bridge:build && electron-builder --win",
    "build:overwolf": "npm run bridge:build && ow-electron-builder --win",
    "pack:overwolf": "npm run bridge:build && ow-electron-builder --dir",
    "pack": "npm run bridge:build && electron-builder --dir",
    "icon:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-icon-assets.ps1",
    "icon:test": "node --test tests/branding.test.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "1.13.6",
    "chokidar": "^3.5.3",
    "electron-store": "^8.1.0",
    "node-global-key-listener": "^0.1.1",
    "tesseract.js": "^5.0.3"
  },
  "devDependencies": {
    "@overwolf/electron-is-overwolf": "^0.0.2",
    "@overwolf/ow-electron": "^39.6.1",
    "@overwolf/ow-electron-builder": "^26.8.4",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.2",
    "playwright": "^1.59.1"
  },
  "build": {
    "appId": "JuiceJournal.Desktop",
    "productName": "Juice Journal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "native-bridge/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "juice-journal",
    "poe",
    "path-of-exile"
  ],
  "author": {
    "name": "Furkan Taşçı"
  },
  "overwolf": {
    "packages": [
      "gep"
    ]
  },
  "license": "MIT"
}
